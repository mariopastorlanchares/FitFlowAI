{
  "name": "fitflowai-functions",
  "private": true,
  "main": "lib/functions/src/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "deploy": "firebase deploy --only functions",
    "genkit:ui": "genkit start -- npx tsx --watch src/index.ts",
    "serve": "npm run build && firebase emulators:start --only functions",
    "test": "npm run build && node --test lib/functions/src/generator-prompt.test.js"
  },
  "dependencies": {
    "@genkit-ai/google-genai": "^1.31.0",
    "firebase-functions": "^7.2.2",
    "genkit": "^1.31.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
