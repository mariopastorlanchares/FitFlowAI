{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "outDir": "lib",
    "rootDir": "..",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "src/**/*.ts",
    "../src/shared/lib/exercise-compatibility.ts",
    "../src/shared/lib/generator-contract.ts",
    "../src/shared/types/exercise-catalog.ts",
    "../src/shared/types/generator-contract.ts",
    "../src/shared/types/user-profile.ts",
    "../src/shared/types/workout-context.ts"
  ],
  "exclude": [
    "lib",
    "node_modules"
  ]
}
